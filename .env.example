# Copy to .env and adjust. The server and migration tooling both read DATABASE_URL.
#
# Option A — dockerized database (recommended; `docker compose up -d db`):
#   the db is published on host port 5433.
DATABASE_URL=postgres://eishera:eishera@localhost:5433/eishera
#
# Option B — a Postgres you run natively on 5432, e.g.:
#   DATABASE_URL=postgres://localhost:5432/eishera
#
# Note: inside docker compose the server talks to the db service directly at
# postgres://eishera:eishera@db:5432/eishera (set in docker-compose.yml, not here).

# HTTP/websocket port for apps/server.
PORT=4000

# Secret used to sign auth JWTs. Set a strong random value in real deployments;
# if unset, the server falls back to an insecure dev default and logs a warning.
JWT_SECRET=dev-insecure-secret-change-me

# Secret for signing the CSRF cookie (defaults to JWT_SECRET if unset).
# COOKIE_SECRET=another-strong-random-value

# Auth cookie / token tuning (optional; sensible defaults shown):
#   COOKIE_SECURE  — Secure (HTTPS-only) cookies. Defaults true when NODE_ENV=production.
#   ACCESS_TTL     — access-token lifetime (e.g. 15m, 1h); cookie max-age tracks this
#   REFRESH_TTL_DAYS — refresh-token lifetime in days (= how long "stay signed in" lasts)
# COOKIE_SECURE=false
# ACCESS_TTL=15m
# REFRESH_TTL_DAYS=30
